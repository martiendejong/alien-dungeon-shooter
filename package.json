{
  "name": "subterra",
  "version": "0.1.0",
  "description": "SUBTERRA - cinematic 2D action-platformer (Alien Dungeon Shooter)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "verify": "esbuild verify_levels.ts --bundle --format=esm --platform=node --outfile=verify.mjs && node verify.mjs",
    "deploy": "node scripts/deploy.mjs"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
